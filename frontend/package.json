{
  "name": "tourgaze-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "gen:api": "npx openapi-typescript ../spec/openapi.json -o ./src/types/schema.ts",
    "gen:enums": "node scripts/gen-enums.js",
    "generate": "npm run gen:api && npm run gen:enums",
    "lint": "eslint . --ext .ts,.vue"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.101.0",
    "@vueuse/core": "^14.3.0",
    "echarts": "^6.1.0",
    "leaflet": "^1.9.4",
    "lucide-vue-next": "^1.0.0",
    "maplibre-gl": "^5.24.0",
    "notivue": "^2.4.5",
    "openapi-fetch": "^0.17.0",
    "splitpanes": "^4.1.2",
    "vue": "^3.5.13",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.19.21",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.5"
  }
}
