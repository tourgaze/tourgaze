<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 1. Inherit Spring Boot's default console formatting + appender. -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- 2. Pull tourgaze.data-dir from application.yaml so logs land beside the
            DB / store, under ~/.tourgaze by default. -->
    <springProperty scope="context" name="DATA_DIR" source="tourgaze.data-dir"
                    defaultValue="${user.home}/.tourgaze"/>
    <property name="LOG_HOME" value="${DATA_DIR}/logs"/>

    <!-- 3. Rolling file appender: daily rotation, gzip'd archives. -->
    <appender name="ROLLING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/tourgaze.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/tourgaze-%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>7</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- 4. Async wrapper so file I/O never blocks request threads. -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="ROLLING_FILE"/>
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
    </appender>

    <!-- 5. Levels — console (Spring's CONSOLE) + rolling file. -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </root>

    <logger name="io.github.tourgaze" level="INFO"/>
</configuration>
